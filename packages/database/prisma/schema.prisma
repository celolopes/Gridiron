generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

model Tenant {
  id                  String               @id @default(uuid())
  slug                String               @unique // Used for /t/[slug] routing
  name                String
  subscriptionPlan    SubscriptionPlan     @default(FREE)
  isSaasEnabled       Boolean              @default(false)
  // Shipping settings
  shippingFlatRate    Float                @default(0)
  freeShippingAbove   Float?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  products            Product[]
  orders              Order[]
  settings            TenantSettings?
  demandScores        DemandScore[]
  purchaseSuggestions PurchaseSuggestion[]
  events              Event[]
  users               User[]   @relation("TenantUsers") // Customers/Staff
  managers            User[]   @relation("StoreManagers") // Users who can manage this store 
}

model TenantSettings {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  brandName           String?
  logoUrl             String?
  heroImageUrl        String?
  primaryColor        String?
  accentColor         String?
  themeMode           String   @default("light") // light, dark, system
  glassOpacity        Float    @default(0.8)
  blurIntensity       Float    @default(10.0)
  domainCustom        String?  @unique
  paymentSettingsJson Json? // Feature flags eg: { paymentModePix: "MANUAL_LINK", paymentModeCard: "MANUAL_LINK" }
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(CUSTOMER)
  tenantId      String?
  tenant        Tenant?  @relation("TenantUsers", fields: [tenantId], references: [id])
  managedStores Tenant[] @relation("StoreManagers")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  SUPPORT
  CUSTOMER
}

model Product {
  id                        String          @id @default(uuid())
  tenantId                  String
  tenant                    Tenant          @relation(fields: [tenantId], references: [id])
  name                      String
  slug                      String          @unique // Added slug for catalog routing
  description               String?
  price                     Float
  // Financial fields
  costPrice                 Float?
  importTaxEstimate         Float?
  internationalShippingCost Float?
  fulfillmentType           FulfillmentType @default(STOCK)
  images                    ProductImage[]
  variants                  Variant[]
  category                  String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  demandScores              DemandScore[]
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model Variant {
  id              String           @id @default(uuid())
  productId       String
  product         Product          @relation(fields: [productId], references: [id])
  sku             String           @unique
  name            String // e.g., "M - Home", "L - Away"
  inventory       Inventory?
  orderItems      OrderItem[]
  supplierProduct SupplierProduct?
  dropshipEnabled Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Inventory {
  id        String   @id @default(uuid())
  variantId String   @unique
  variant   Variant  @relation(fields: [variantId], references: [id])
  available Int      @default(0)
  reserved  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id                  String            @id @default(uuid())
  name                String
  contactEmail        String?
  leadTimeDays        Int               @default(15)
  supportsDropshipping Boolean           @default(true)
  supplierProducts    SupplierProduct[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model SupplierProduct {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  variantId  String   @unique // 1:1 for simplicity in MVP, could be 1:N
  variant    Variant  @relation(fields: [variantId], references: [id])
  costPrice  Float
  leadTime   Int // Days to ship
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum ShippingType {
  FIXED
  FREE_OVER_AMOUNT
  DROPSHIP_DIRECT
}

model Order {
  id                      String      @id @default(uuid())
  orderNumber             String      @unique
  tenantId                String
  tenant                  Tenant      @relation(fields: [tenantId], references: [id])
  userId                  String?
  customerEmail           String
  customerName            String
  customerPhone           String?
  addressStreet           String?
  addressNumber           String?
  addressCity             String?
  addressState            String?
  addressZipCode          String?
  totalAmount             Float
  shippingAmount          Float       @default(0)
  shippingType            ShippingType @default(FIXED)
  status                  OrderStatus @default(REQUESTED_PAYMENT)
  paymentLinkManualUrl    String?
  paymentMethodPreference String?
  paidAt                  DateTime?
  orderItems              OrderItem[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id])
  variantId       String
  variant         Variant         @relation(fields: [variantId], references: [id])
  quantity        Int
  price           Float // Price at time of purchase
  fulfillmentType FulfillmentType @default(STOCK)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum OrderStatus {
  REQUESTED_PAYMENT
  LINK_SENT
  PAID
  FORWARD_TO_SUPPLIER
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum FulfillmentType {
  STOCK
  DROPSHIP
  ON_DEMAND
}

model DemandScore {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  score     Float    @default(0)
  period    String // e.g., "7d", "14d", "30d"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, productId, period])
}

model PurchaseSuggestion {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  variantSku   String // Linked to Variant by SKU for loose coupling or directly
  suggestedQty Int
  reason       String?
  createdAt    DateTime @default(now())
}

model Event {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  eventType String // e.g., "PURCHASE", "PRODUCT_VIEW", "VIEW"
  metadata  Json?
  createdAt DateTime @default(now())
}
